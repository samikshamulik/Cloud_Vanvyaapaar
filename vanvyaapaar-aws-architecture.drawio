    <mxCell id="ec2-be-note" value="Instance: t3.medium (ap-south-1a)&#xa;OS: Amazon Linux 2 + Java 17 (Corretto)&#xa;App: Spring Boot 3.5.6 JAR&#xa;Port: 8080 (HTTP)&#xa;Start: java -jar vanvyaapaar.jar&#xa;Auth: Spring Security + JWT (JJWT 0.11.5)&#xa;ORM: Spring Data JPA / Hibernate&#xa;SG: sg-backend | Port 8080 from sg-alb only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF0E0;strokeColor=#ED7100;fontSize=14;align=left;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="1000" y="990" width="540" height="140" as="geometry" />
    </mxCell>

