    <mxCell id="deploy-box" value="Deployment Steps (on EC2)" style="swimlane;startSize=36;fillColor=#E3F2FD;strokeColor=#1565C0;fontStyle=1;fontSize=16;" vertex="1" parent="1">
      <mxGeometry x="780" y="1060" width="860" height="340" as="geometry" />
    </mxCell>
    <mxCell id="d-fe" value="Frontend EC2:&#xa;1. ssh into EC2&#xa;2. npm install --legacy-peer-deps&#xa;3. npm run build  (generates dist/)&#xa;4. sudo cp -r dist/* /usr/share/nginx/html/&#xa;5. sudo systemctl restart nginx" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=14;align=left;spacingLeft=8;verticalAlign=top;" vertex="1" parent="deploy-box">
      <mxGeometry x="20" y="50" width="380" height="130" as="geometry" />
    </mxCell>
    <mxCell id="d-be" value="Backend EC2:&#xa;1. ssh into EC2&#xa;2. mvnw clean package -DskipTests&#xa;3. scp target/vanvaapyaar.jar → EC2&#xa;4. java -jar vanvaapyaar.jar \&#xa;     --spring.datasource.url=jdbc:mysql://&lt;rds-endpoint&gt;:3306/vanvyaapaar \&#xa;     --spring.datasource.username=admin \&#xa;     --spring.datasource.password=&lt;from-secrets-manager&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=14;align=left;spacingLeft=8;verticalAlign=top;" vertex="1" parent="deploy-box">
      <mxGeometry x="440" y="50" width="400" height="160" as="geometry" />
    </mxCell>
    <mxCell id="d-env" value="application.properties on EC2:&#xa;spring.datasource.url=jdbc:mysql://&lt;rds-endpoint&gt;:3306/vanvyaapaar&#xa;jwt.secret=&lt;from-secrets-manager&gt;&#xa;server.port=8080" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#4CAF50;fontSize=14;align=left;spacingLeft=8;fontFamily=Courier New;" vertex="1" parent="deploy-box">
      <mxGeometry x="20" y="210" width="820" height="80" as="geometry" />
    </mxCell>

