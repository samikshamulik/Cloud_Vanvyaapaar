    <mxCell id="alb-note" value="Listener: HTTP :80 → HTTPS :443&#xa;Rule 1: /api/* → EC2 Backend :8080&#xa;Rule 2: /* → EC2 Frontend :80&#xa;SG: sg-alb | Inbound 80,443 from 0.0.0.0/0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EF;strokeColor=#E7157B;fontSize=14;align=left;spacingLeft=8;" vertex="1" parent="1">
