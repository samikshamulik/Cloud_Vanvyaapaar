    <mxCell id="ec2-fe-note" value="Instance: t3.small (ap-south-1a)&#xa;OS: Amazon Linux 2&#xa;Web Server: Nginx 1.24&#xa;Serves: React 18 + Vite build (dist/)&#xa;Port: 80 (HTTP)&#xa;nginx.conf: try_files → index.html&#xa;/api/* proxy_pass → Backend :8080&#xa;SG: sg-frontend | Port 80 from sg-alb only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF0E0;strokeColor=#ED7100;fontSize=14;align=left;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="460" y="990" width="520" height="140" as="geometry" />
