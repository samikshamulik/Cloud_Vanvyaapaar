      <mxGeometry x="2600" y="400" width="70" height="70" as="geometry" />
    </mxCell>
    <mxCell id="cw-detail" value="Logs: ECS containers, ALB access&#xa;Metrics: RDS, ECS CPU/Memory&#xa;Alarms &amp; Dashboards" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EF;strokeColor=#E7157B;fontSize=14;align=left;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="2560" y="490" width="300" height="60" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════
         CI/CD PIPELINE
    ═══════════════════════════════════ -->
    <mxCell id="cicd-border" value="CI/CD Pipeline" style="swimlane;startSize=46;fillColor=#F8F8F8;strokeColor=#555;fontColor=#232F3E;fontStyle=1;fontSize=22;" vertex="1" parent="1">
      <mxGeometry x="100" y="2240" width="3060" height="310" as="geometry" />
    </mxCell>

    <mxCell id="gh" value="GitHub" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.general;fillColor=#F05032;strokeColor=none;fontColor=#232F3E;fontSize=16;verticalLabelPosition=bottom;verticalAlign=top;labelBackgroundColor=none;sketch=0;aspect=fixed;" vertex="1" parent="cicd-border">
      <mxGeometry x="60" y="80" width="80" height="80" as="geometry" />
    </mxCell>
    <mxCell id="gh-detail" value="Source repo&#xa;Jenkinsfile&#xa;Dockerfile ×2&#xa;k8s/ manifests" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDECEA;strokeColor=#F05032;fontSize=14;" vertex="1" parent="cicd-border">
      <mxGeometry x="50" y="180" width="120" height="70" as="geometry" />
    </mxCell>

    <mxCell id="jenkins-box" value="Jenkins Server&#xa;─────────────────&#xa;1. Checkout source&#xa;2. mvn clean install (tests)&#xa;3. npm install --legacy-peer-deps&#xa;4. npm run build&#xa;5. docker build frontend&#xa;6. docker build backend&#xa;7. Push both to ECR&#xa;8. ecs update-service" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6E4F7;strokeColor=#5B93C5;fontSize=15;align=left;spacingLeft=10;verticalAlign=top;" vertex="1" parent="cicd-border">
      <mxGeometry x="240" y="60" width="340" height="220" as="geometry" />
    </mxCell>

    <mxCell id="docker-box" value="Docker Build&#xa;─────────────────&#xa;Frontend Dockerfile:&#xa;  FROM node → build&#xa;  FROM nginx:alpine&#xa;  COPY /app/dist → /usr/share/nginx/html&#xa;&#xa;Backend Dockerfile:&#xa;  FROM maven → mvn package&#xa;  FROM openjdk:17-slim&#xa;  CMD java -jar app.jar" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6E4F7;strokeColor=#5B93C5;fontSize=15;align=left;spacingLeft=10;verticalAlign=top;" vertex="1" parent="cicd-border">
      <mxGeometry x="640" y="60" width="380" height="220" as="geometry" />
    </mxCell>

    <mxCell id="ecr-push-box" value="ECR Push&#xa;─────────────────&#xa;aws ecr get-login-password \&#xa;  --region ap-south-1 |&#xa;docker login --username AWS \&#xa;  --password-stdin &lt;acct&gt;.dkr.ecr...&#xa;&#xa;docker tag frontend:latest → ECR&#xa;docker push frontend:latest&#xa;docker tag backend:latest → ECR&#xa;docker push backend:latest" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6E4F7;strokeColor=#5B93C5;fontSize=15;align=left;spacingLeft=10;verticalAlign=top;fontFamily=Courier New;" vertex="1" parent="cicd-border">
      <mxGeometry x="1080" y="60" width="440" height="220" as="geometry" />
    </mxCell>

    <mxCell id="ecs-deploy-box" value="ECS Deploy&#xa;─────────────────&#xa;aws ecs update-service \&#xa;  --cluster vanvyaapaar-cluster \&#xa;  --service frontend-service \&#xa;  --force-new-deployment&#xa;&#xa;aws ecs update-service \&#xa;  --cluster vanvyaapaar-cluster \&#xa;  --service backend-service \&#xa;  --force-new-deployment&#xa;Strategy: Rolling update (0 downtime)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6E4F7;strokeColor=#5B93C5;fontSize=15;align=left;spacingLeft=10;verticalAlign=top;fontFamily=Courier New;" vertex="1" parent="cicd-border">
      <mxGeometry x="1580" y="60" width="480" height="220" as="geometry" />
    </mxCell>

    <mxCell id="k8s-box" value="Alt: Kubernetes (EKS)&#xa;k8s/deployment.yaml&#xa;k8s/service.yml&#xa;(available as alternative)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=14;align=left;spacingLeft=8;" vertex="1" parent="cicd-border">
      <mxGeometry x="2140" y="100" width="280" height="80" as="geometry" />
    </mxCell>

    <!-- Local Dev note -->
    <mxCell id="localdev" value="Local Dev:&#xa;Backend  → localhost:8080 (mvn spring-boot:run)&#xa;Frontend → localhost:5173 (npm run dev)&#xa;DB       → localhost:3306 (MySQL 8)&#xa;Docker Compose → frontend:3000 + backend:8080" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=14;align=left;spacingLeft=8;" vertex="1" parent="cicd-border">
      <mxGeometry x="2500" y="60" width="460" height="100" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════
         TRAFFIC FLOW LEGEND
    ═══════════════════════════════════ -->
    <mxCell id="legend-box" value="Traffic Flow Legend" style="swimlane;startSize=36;fillColor=#F5F5F5;strokeColor=#666;fontSize=18;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="100" y="2600" width="720" height="200" as="geometry" />
    </mxCell>

    <mxCell id="l1" value="HTTPS User Traffic (Route53 → CF → ALB → ECS)" style="text;html=1;fontSize=15;strokeColor=none;fillColor=none;" vertex="1" parent="legend-box">
      <mxGeometry x="140" y="55" width="520" height="26" as="geometry" />
    </mxCell>
    <mxCell id="l1-line" value="" style="endArrow=block;endFill=1;strokeColor=#0078D4;strokeWidth=3;" edge="1" parent="legend-box">
      <mxGeometry x="30" y="68" width="100" height="10" as="geometry"><Array as="points"><mxPoint x="120" y="68"/></Array></mxGeometry>
    </mxCell>

    <mxCell id="l2" value="Internal Service Calls (ECS ↔ RDS, Secrets Manager)" style="text;html=1;fontSize=15;strokeColor=none;fillColor=none;" vertex="1" parent="legend-box">
      <mxGeometry x="140" y="95" width="520" height="26" as="geometry" />
    </mxCell>
    <mxCell id="l2-line" value="" style="endArrow=block;endFill=1;strokeColor=#2E73B8;strokeWidth=2;dashed=1;" edge="1" parent="legend-box">
      <mxGeometry x="30" y="108" width="100" height="10" as="geometry"><Array as="points"><mxPoint x="120" y="108"/></Array></mxGeometry>
    </mxCell>

    <mxCell id="l3" value="CI/CD Deployment (GitHub → Jenkins → ECR → ECS)" style="text;html=1;fontSize=15;strokeColor=none;fillColor=none;" vertex="1" parent="legend-box">
      <mxGeometry x="140" y="135" width="520" height="26" as="geometry" />
    </mxCell>
    <mxCell id="l3-line" value="" style="endArrow=block;endFill=1;strokeColor=#F05032;strokeWidth=2;dashed=1;" edge="1" parent="legend-box">
      <mxGeometry x="30" y="148" width="100" height="10" as="geometry"><Array as="points"><mxPoint x="120" y="148"/></Array></mxGeometry>
    </mxCell>

    <!-- ═══════════════════════════════════
         CONNECTIONS
    ═══════════════════════════════════ -->

    <!-- Users → Route53 -->
    <mxCell id="c-u-r53" value="HTTPS DNS Query" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#0078D4;strokeWidth=3;endArrow=block;endFill=1;fontSize=12;fontColor=#0078D4;" edge="1" parent="1" source="user-seller" target="route53">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Route53 → CloudFront -->
    <mxCell id="c-r53-cf" value="Resolves to distribution" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#0078D4;strokeWidth=3;endArrow=block;endFill=1;fontSize=12;fontColor=#0078D4;" edge="1" parent="1" source="route53" target="cloudfront">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- WAF → CloudFront -->
    <mxCell id="c-waf-cf" value="Filter" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#DD344C;strokeWidth=2;endArrow=block;endFill=1;dashed=1;fontSize=12;" edge="1" parent="1" source="waf" target="cloudfront">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- CloudFront → ALB -->
    <mxCell id="c-cf-alb" value="/api/* requests" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#0078D4;strokeWidth=3;endArrow=block;endFill=1;fontSize=12;fontColor=#0078D4;" edge="1" parent="1" source="cloudfront" target="alb">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- IGW → ALB -->
    <mxCell id="c-igw-alb" value="" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#7AA116;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="igw" target="alb">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- ALB → Frontend ECS -->
    <mxCell id="c-alb-fe" value="/* → :3000" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#E7157B;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontColor=#E7157B;" edge="1" parent="1" source="alb" target="fe-task-icon">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- ALB → Backend ECS -->
    <mxCell id="c-alb-be" value="/api/* → :8080" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#E7157B;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontColor=#E7157B;" edge="1" parent="1" source="alb" target="be-task-icon">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Frontend → Backend (nginx proxy) -->
    <mxCell id="c-fe-be" value="Nginx proxy /api" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6C8EBF;strokeWidth=2;endArrow=block;endFill=1;dashed=1;fontSize=12;" edge="1" parent="1" source="fe-task-icon" target="be-task-icon">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Backend → RDS -->
    <mxCell id="c-be-rds" value="JDBC :3306&#xa;Spring Data JPA" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2E73B8;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontColor=#2E73B8;" edge="1" parent="1" source="be-task-icon" target="rds-icon">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Backend → Secrets -->
    <mxCell id="c-be-sec" value="Fetch secrets" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#DD344C;strokeWidth=2;endArrow=block;endFill=1;dashed=1;fontSize=12;" edge="1" parent="1" source="be-task-icon" target="secrets">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- ECR → Frontend -->
    <mxCell id="c-ecr-fe" value="docker pull" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#E7157B;strokeWidth=2;endArrow=block;endFill=1;dashed=1;fontSize=12;" edge="1" parent="1" source="ecr" target="fe-task-icon">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- ECR → Backend -->
    <mxCell id="c-ecr-be" value="docker pull" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#E7157B;strokeWidth=2;endArrow=block;endFill=1;dashed=1;fontSize=12;" edge="1" parent="1" source="ecr" target="be-task-icon">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- CI/CD → ECR (fixed: parent="1" to avoid cross-parent edge issue) -->
    <mxCell id="c-cd-ecr" value="aws ecr push" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#F05032;strokeWidth=2;endArrow=block;endFill=1;dashed=1;fontSize=14;" edge="1" parent="1" source="ecr-push-box" target="ecr">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Backend → CloudWatch -->
    <mxCell id="c-be-cw" value="logs" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#E7157B;strokeWidth=1.5;endArrow=open;dashed=1;fontSize=11;" edge="1" parent="1" source="be-task-icon" target="cloudwatch">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <!-- Frontend → CloudWatch -->
    <mxCell id="c-fe-cw" value="logs" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#E7157B;strokeWidth=1.5;endArrow=open;dashed=1;fontSize=11;" edge="1" parent="1" source="fe-task-icon" target="cloudwatch">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- CI/CD internal arrows -->
    <mxCell id="cc1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#F05032;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="cicd-border" source="gh" target="jenkins-box">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="cc2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#5B93C5;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="cicd-border" source="jenkins-box" target="docker-box">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="cc3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#5B93C5;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="cicd-border" source="docker-box" target="ecr-push-box">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="cc4" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#5B93C5;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="cicd-border" source="ecr-push-box" target="ecs-deploy-box">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

  </root>
</mxGraphModel>
